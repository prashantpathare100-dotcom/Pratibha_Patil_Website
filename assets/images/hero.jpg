<!-- This is a placeholder note - create a simple SVG with gradient -->
<svg xmlns="http://www.w3.org/2000/svg" width="1200" height="600" viewBox="0 0 1200 600">
    <defs>
        <linearGradient id="grad" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" style="stop-color:#FF9933;stop-opacity:1" />
            <stop offset="100%" style="stop-color:#000080;stop-opacity:1" />
        </linearGradient>
    </defs>
    <rect width="1200" height="600" fill="url(#grad)"/>
    <circle cx="900" cy="150" r="100" fill="rgba(255,255,255,0.1)"/>
    <circle cx="200" cy="400" r="150" fill="rgba(255,255,255,0.1)"/>
    <text x="600" y="300" text-anchor="middle" fill="#FFFFFF" font-size="48" font-family="Arial" font-weight="bold">Pratibha Patil</text>
    <text x="600" y="380" text-anchor="middle" fill="#FFFFFF" font-size="24" font-family="Arial">First Female President of India</text>
</svg>